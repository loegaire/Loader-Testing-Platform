<!--
  Sysmon Configuration - Optimized for Shellcode Loader Detection

  Purpose: Capture telemetry relevant to the 6-stage loader pipeline.
  Install: sysmon.exe -accepteula -i sysmon_loader_config.xml
  Update:  sysmon.exe -c sysmon_loader_config.xml

  Stage mapping (event signal expected per stage):
    L0 (Anti-Analysis) -> No direct Sysmon coverage (ETW/debugger level)
    L1 (Storage)       -> Event 11 (FileCreate), Event 3 (NetworkConnect),
                          Event 22 (DnsQuery)
    L2 (Allocation)    -> Event 10 (ProcessAccess) when remote (T2.3);
                          no direct event for local VirtualAlloc
    L4 (Writing)       -> Event 10 (ProcessAccess) when remote (T4.3);
                          no direct event for local memcpy / VirtualProtect
    L5 (Execution)     -> Event 1 (ProcessCreate) for child spawn;
                          Event 8 (CreateRemoteThread) when remote (T5.4);
                          Event 25 (ProcessTampering) for hollowing

  Remote-chain (T2.3 + T4.3 + T5.4) signal preview:
    - Event 1:  ProcessCreate parent=payload.exe child=notepad.exe (suspended)
    - Event 10: ProcessAccess source=payload.exe target=notepad.exe
                (covers VirtualAllocEx + WriteProcessMemory access patterns)
    - Event 8:  CreateRemoteThread source=payload.exe target=notepad.exe,
                StartAddress = remote-allocated buffer
-->
<Sysmon schemaversion="4.91">
  <HashAlgorithms>SHA256</HashAlgorithms>

  <EventFiltering>

    <!-- ================================================================== -->
    <!-- Event 1: ProcessCreate                                             -->
    <!-- Stage: L5 (Execution) — loader invocation only.                   -->
    <!--                                                                    -->
    <!-- Scope decision: the loader's responsibility ends when the         -->
    <!-- shellcode is executing. What the shellcode does next (spawning a  -->
    <!-- cmd.exe reverse shell, for example) is shellcode/payload          -->
    <!-- behavior, not loader behavior. We therefore exclude shellcode-    -->
    <!-- spawned children (cmd.exe, conhost.exe) via the exclude rule.     -->
    <!--                                                                    -->
    <!-- Include rules: only the loader binary being invoked, or the       -->
    <!-- spawn-suspended target (T2.4: payload -> notepad.exe).            -->
    <!-- ================================================================== -->
    <RuleGroup name="ProcessCreate-Exclude" groupRelation="or">
      <ProcessCreate onmatch="exclude">
        <!-- Shellcode-spawned shell and its console host (payload behavior) -->
        <ParentImage condition="contains">\Desktop\</ParentImage>
        <Image condition="end with">cmd.exe</Image>
        <Image condition="end with">conhost.exe</Image>
      </ProcessCreate>
    </RuleGroup>

    <RuleGroup name="ProcessCreate-Include" groupRelation="or">
      <ProcessCreate onmatch="include">
        <!-- Loader invocation: payload.exe being launched -->
        <Image condition="contains">\Desktop\</Image>
        <!-- Spawn-suspended target when using T2.4 -->
        <Image condition="end with">notepad.exe</Image>
        <Image condition="end with">rundll32.exe</Image>
      </ProcessCreate>
    </RuleGroup>

    <!-- ================================================================== -->
    <!-- Event 3: NetworkConnect                                            -->
    <!-- Stage: L1 (Storage, future) and shellcode C2 callback             -->
    <!-- ================================================================== -->
    <!-- ================================================================== -->
    <!-- Event 3: NetworkConnect                                            -->
    <!-- Stage: L1 (future network-backed storage technique).              -->
    <!--                                                                    -->
    <!-- Note: the C2 callback that the msfvenom reverse-TCP shellcode     -->
    <!-- makes after execution is SHELLCODE behavior, not loader           -->
    <!-- behavior, and is out of scope. We therefore only log connections  -->
    <!-- originating from the payload binary itself (not from shellcode-   -->
    <!-- spawned children) and ignore the destination port entirely. When  -->
    <!-- a future L1 technique pulls the payload from a URL, the same      -->
    <!-- rule will capture it.                                              -->
    <!-- ================================================================== -->
    <RuleGroup name="NetworkConnect" groupRelation="or">
      <NetworkConnect onmatch="include">
        <Image condition="contains">\Desktop\</Image>
      </NetworkConnect>
    </RuleGroup>

    <!-- ================================================================== -->
    <!-- Event 7: ImageLoad                                                 -->
    <!-- Stage: L2 (future module-stomping techniques). Limited to payload  -->
    <!-- to avoid drowning in legitimate DLL loads.                         -->
    <!-- ================================================================== -->
    <RuleGroup name="ImageLoad" groupRelation="or">
      <ImageLoad onmatch="include">
        <Image condition="contains">\Desktop\</Image>
      </ImageLoad>
    </RuleGroup>

    <!-- ================================================================== -->
    <!-- Event 8: CreateRemoteThread                                        -->
    <!-- Stage: L5 (Execution) — fires for the remote chain (T5.4).        -->
    <!-- Excludes are boot-time / system processes that always do this.    -->
    <!-- ================================================================== -->
    <RuleGroup name="CreateRemoteThread" groupRelation="or">
      <CreateRemoteThread onmatch="exclude">
        <SourceImage condition="end with">csrss.exe</SourceImage>
        <SourceImage condition="end with">lsass.exe</SourceImage>
        <SourceImage condition="end with">services.exe</SourceImage>
        <SourceImage condition="end with">svchost.exe</SourceImage>
        <SourceImage condition="end with">MsMpEng.exe</SourceImage>
        <SourceImage condition="end with">vmtoolsd.exe</SourceImage>
        <SourceImage condition="end with">winlogon.exe</SourceImage>
        <SourceImage condition="end with">wininit.exe</SourceImage>
        <SourceImage condition="end with">smss.exe</SourceImage>
        <SourceImage condition="end with">dwm.exe</SourceImage>
      </CreateRemoteThread>
    </RuleGroup>

    <!-- ================================================================== -->
    <!-- Event 10: ProcessAccess                                            -->
    <!-- Stage: L2 + L4 (Allocation + Writing) — fires for the remote      -->
    <!-- chain when payload accesses the target process for VirtualAllocEx -->
    <!-- and WriteProcessMemory.                                            -->
    <!-- ================================================================== -->
    <RuleGroup name="ProcessAccess-Exclude" groupRelation="or">
      <ProcessAccess onmatch="exclude">
        <!-- Shellcode spawning a cmd reverse-shell is payload behavior,
             not loader behavior — exclude it so the log captures only
             the loader's allocation/write/execute accesses. -->
        <TargetImage condition="end with">cmd.exe</TargetImage>
        <TargetImage condition="end with">conhost.exe</TargetImage>
      </ProcessAccess>
    </RuleGroup>

    <RuleGroup name="ProcessAccess-Include" groupRelation="or">
      <ProcessAccess onmatch="include">
        <SourceImage condition="contains">\Desktop\</SourceImage>
      </ProcessAccess>
    </RuleGroup>

    <!-- ================================================================== -->
    <!-- Event 11: FileCreate — exclusions                                  -->
    <!-- Drop files our own test harness writes to Desktop on every run.    -->
    <!-- ================================================================== -->
    <RuleGroup name="FileCreate-Exclude" groupRelation="or">
      <FileCreate onmatch="exclude">
        <TargetFilename condition="end with">detection_log.txt</TargetFilename>
        <TargetFilename condition="end with">detection_log.csv</TargetFilename>
        <TargetFilename condition="end with">sysmon.xml</TargetFilename>
        <TargetFilename condition="end with">collect_logs.ps1</TargetFilename>
      </FileCreate>
    </RuleGroup>

    <!-- ================================================================== -->
    <!-- Event 11: FileCreate — inclusions                                  -->
    <!-- Stage: L1 (Storage). Capture writes under Desktop so payload       -->
    <!-- deployment and any future disk-based L1 technique are visible.     -->
    <!-- ================================================================== -->
    <RuleGroup name="FileCreate-Include" groupRelation="or">
      <FileCreate onmatch="include">
        <TargetFilename condition="contains">\Desktop\</TargetFilename>
      </FileCreate>
    </RuleGroup>

    <!-- ================================================================== -->
    <!-- Event 13: RegistryEvent                                            -->
    <!-- Stage: L1 (future registry-based storage)                          -->
    <!-- ================================================================== -->
    <RuleGroup name="RegistryEvent" groupRelation="or">
      <RegistryEvent onmatch="include">
        <Image condition="contains">\Desktop\</Image>
      </RegistryEvent>
    </RuleGroup>

    <!-- ================================================================== -->
    <!-- Event 22: DnsQuery                                                 -->
    <!-- Stage: L1 (future DNS-based payload download)                      -->
    <!-- ================================================================== -->
    <RuleGroup name="DnsQuery" groupRelation="or">
      <DnsQuery onmatch="include">
        <Image condition="contains">\Desktop\</Image>
      </DnsQuery>
    </RuleGroup>

    <!-- ================================================================== -->
    <!-- Event 25: ProcessTampering                                         -->
    <!-- Stage: L5 (future hollowing/herpaderping). Limited to payload     -->
    <!-- to filter out boot-time legitimate image swaps.                   -->
    <!-- ================================================================== -->
    <RuleGroup name="ProcessTampering" groupRelation="or">
      <ProcessTampering onmatch="include">
        <Image condition="contains">\Desktop\</Image>
      </ProcessTampering>
    </RuleGroup>

    <!-- ================================================================== -->
    <!-- Event 26: FileDeleteDetected                                       -->
    <!-- Captures AV quarantine deletes targeting payload on Desktop.      -->
    <!-- ================================================================== -->
    <RuleGroup name="FileDeleteDetected" groupRelation="or">
      <FileDeleteDetected onmatch="include">
        <TargetFilename condition="contains">\Desktop\</TargetFilename>
      </FileDeleteDetected>
    </RuleGroup>

  </EventFiltering>
</Sysmon>
